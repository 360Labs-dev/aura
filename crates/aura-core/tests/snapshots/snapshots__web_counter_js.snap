// Aura App ŌĆö Generated by Aura Compiler
'use strict';

let _actionRegistry = Object.create(null);
let _actionId = 0;
function _registerAction(fn) {
  const id = `action-${++_actionId}`;
  _actionRegistry[id] = fn;
  return id;
}

function _invokeAction(id) {
  const action = _actionRegistry[id];
  if (typeof action === 'function') {
    action();
  }
}

const _state = {
  count: 0,
};

const state = new Proxy(_state, {
  set(target, prop, value) {
    target[prop] = value;
    _scheduleRender();
    return true;
  }
});

let _renderPending = false;
function _scheduleRender() {
  if (!_renderPending) {
    _renderPending = true;
    requestAnimationFrame(() => { _renderPending = false; render(); });
  }
}

function increment() {
  state.count = (state.count + 1);
}

function decrement() {
  state.count = (state.count - 1);
}

function render() {
  const app = document.getElementById('app');
  if (!app) return;
  _actionRegistry = Object.create(null);
  _actionId = 0;
  app.innerHTML = renderView();
  _bindEvents();
}

function renderView() {
  return `
        <div class="aura-column text-center" style="gap: 16px; padding: 24px; text-align: center; align-items: center">
            <h1 class="aura-heading" style="font-size: 1.5rem">Counter</h1>
            <span class="aura-text text-bold" style="font-size: 3rem">${state.count}</span>
            <div class="aura-row" style="gap: 8px">
                <button class="aura-button color-danger" data-action-id="${_registerAction(() => { decrement() })}">-</button>
                <button class="aura-button color-accent" data-action-id="${_registerAction(() => { increment() })}">+</button>
            </div>
        </div>
`;
}

