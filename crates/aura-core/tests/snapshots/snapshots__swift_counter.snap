import SwiftUI

struct MainView: View {
    @State private var count: Int = 0

    var body: some View {
        VStack(spacing: 16) {
            Text(count)
            Button("+", action: { increment() })
                .buttonStyle(.borderedProminent)
                .tint(.accentColor)
        }
            .padding(24)
    }

    func increment() {
        count = (count + 1)
    }
}

@main
struct CounterApp: App {
    var body: some Scene {
        WindowGroup {
            NavigationStack {
                MainView()
            }
        }
    }
}
