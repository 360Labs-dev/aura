// Aura App тАФ Generated by Aura Compiler
'use strict';

const _state = {
  tasks: [],
  input: "",
};

const state = new Proxy(_state, {
  set(target, prop, value) {
    target[prop] = value;
    _scheduleRender();
    return true;
  }
});

let _renderPending = false;
function _scheduleRender() {
  if (!_renderPending) {
    _renderPending = true;
    requestAnimationFrame(() => { _renderPending = false; render(); });
  }
}

function Task(fields) {
  return { title: fields.title ?? null, done: fields.done ?? false };
}

function addTask(title) {
  state.tasks = [...state.tasks, Task({ title: title })];
}

function render() {
  const app = document.getElementById('app');
  if (!app) return;
  app.innerHTML = renderView();
  _bindEvents();
}

function renderView() {
  return `
        <div class="aura-column" style="gap: 8px; padding: 16px">
            <h1 class="aura-heading">Tasks</h1>
            <div class="aura-row" style="gap: 4px">
                <input class="aura-input" type="text" placeholder="New task..." data-bind="input" value="${state.input || ''}"/>
                <button class="aura-button color-accent" onclick="addTask(state.input)">Add</button>
            </div>
${state.tasks.map((task, _idx) => `<div class="aura-row text-center" style="gap: 8px; text-align: center; align-items: center">
                    <input class="aura-checkbox" type="checkbox" data-bind="task.done" ${(task.done) ? 'checked' : ''}/>
                    <span class="aura-text">${task.title}</span>
                </div>`).join('')}        </div>
`;
}

const _icons = {'arrow.up':'тмЖя╕П','arrow.up.circle.fill':'тмЖя╕П','trash':'ЁЯЧС','trash.fill':'ЁЯЧС','plus':'+','plus.circle':'+','minus':'тИТ','star':'тнР','star.fill':'тнР','heart':'тЭдя╕П','heart.fill':'тЭдя╕П','checkmark':'тЬЕ','checkmark.circle':'тЬЕ','xmark':'тЭМ','magnifyingglass':'ЁЯФН','gear':'тЪЩя╕П','person':'ЁЯСд','house':'ЁЯПа','bell':'ЁЯФФ','camera':'ЁЯУ╖','photo':'ЁЯЦ╝я╕П','sun.max':'тШАя╕П','cloud':'тШБя╕П','cloud.rain':'ЁЯМзя╕П','cloud.snow':'ЁЯМия╕П','drop':'ЁЯТз','wind':'ЁЯТи','lock.circle':'ЁЯФТ','lock':'ЁЯФТ','phone':'ЁЯУЮ','video':'ЁЯУ╣','mic':'ЁЯОд','cart':'ЁЯЫТ','inbox':'ЁЯУе','square.and.pencil':'тЬПя╕П','bubble.left.and.bubble.right':'ЁЯТм',};
function _icon(n) { return _icons[n] || n; }

function _bindEvents() {
  // Bind input elements to state
  document.querySelectorAll('[data-bind]').forEach(el => {
    const key = el.dataset.bind;
    if (el.type === 'checkbox') {
      el.checked = !!state[key];
      el.onchange = () => { state[key] = el.checked; };
    } else {
      el.value = state[key] || '';
      el.oninput = () => { state[key] = el.value; };
    }
  });
}

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', render);
