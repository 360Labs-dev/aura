// Aura App — Generated by Aura Compiler
'use strict';

let _actionRegistry = Object.create(null);
let _actionId = 0;
function _registerAction(fn) {
  const id = `action-${++_actionId}`;
  _actionRegistry[id] = fn;
  return id;
}

function _invokeAction(id) {
  const action = _actionRegistry[id];
  if (typeof action === 'function') {
    action();
  }
}

const _state = {
  tasks: [],
  input: "",
};

const state = new Proxy(_state, {
  set(target, prop, value) {
    target[prop] = value;
    _scheduleRender();
    return true;
  }
});

let _renderPending = false;
function _scheduleRender() {
  if (!_renderPending) {
    _renderPending = true;
    requestAnimationFrame(() => { _renderPending = false; render(); });
  }
}

function Task(fields) {
  return { title: fields.title ?? null, done: fields.done ?? false };
}

function addTask(title) {
  state.tasks = [...state.tasks, Task({ title: title })];
}

function render() {
  const app = document.getElementById('app');
  if (!app) return;
  // Save focused element
  const focused = document.activeElement;
  const focusedBind = focused?.dataset?.bind;
  const focusedPos = focused?.selectionStart;
  app.innerHTML = renderView();
  _bindEvents();
  // Restore focus
  if (focusedBind) {
    const el = document.querySelector(`[data-bind="${focusedBind}"]`);
    if (el) { el.focus(); if (focusedPos != null) try { el.setSelectionRange(focusedPos, focusedPos); } catch(e) {} }
  }
}

function renderView() {
  return `
        <div class="aura-column" style="gap: 8px; padding: 16px">
            <h1 class="aura-heading">Tasks</h1>
            <div class="aura-row" style="gap: 4px">
                <input class="aura-input" type="text" placeholder="New task..." data-bind="input" value="${state.input || ''}"/>
                <button class="aura-button color-accent" data-action-id="${_registerAction(() => { addTask(state.input) })}">Add</button>
            </div>
${state.tasks.map((task, _idx) => `<div class="aura-row text-center" style="gap: 8px; text-align: center; align-items: center">
                    <input class="aura-checkbox" type="checkbox" data-bind="task.done" ${(task.done) ? 'checked' : ''}/>
                    <span class="aura-text">${task.title}</span>
                </div>`).join('')}        </div>
`;
}

const _icons = {'arrow.up':'⬆️','arrow.up.circle.fill':'⬆️','trash':'🗑','trash.fill':'🗑','plus':'+','plus.circle':'+','minus':'−','star':'⭐','star.fill':'⭐','heart':'❤️','heart.fill':'❤️','checkmark':'✅','checkmark.circle':'✅','xmark':'❌','magnifyingglass':'🔍','gear':'⚙️','person':'👤','house':'🏠','bell':'🔔','camera':'📷','photo':'🖼️','sun.max':'☀️','cloud':'☁️','cloud.rain':'🌧️','cloud.snow':'🌨️','drop':'💧','wind':'💨','lock.circle':'🔒','lock':'🔒','phone':'📞','video':'📹','mic':'🎤','cart':'🛒','inbox':'📥','square.and.pencil':'✏️','bubble.left.and.bubble.right':'💬',};
function _icon(n) { return _icons[n] || n; }

function _bindEvents() {
  document.querySelectorAll('[data-action-id]').forEach(el => {
    const id = el.dataset.actionId;
    el.onclick = event => {
      event.preventDefault();
      _invokeAction(id);
    };
  });
  // Bind input elements to state
  document.querySelectorAll('[data-bind]').forEach(el => {
    const key = el.dataset.bind;
    if (el.type === 'checkbox') {
      el.checked = !!state[key];
      el.onchange = () => { state[key] = el.checked; };
    } else {
      el.value = state[key] || '';
      el.oninput = () => { state[key] = el.value; };
    }
  });
}

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', render);
