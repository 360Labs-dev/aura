// Aura App — Generated by Aura Compiler
'use strict';

let _actionRegistry = Object.create(null);
let _actionId = 0;
function _registerAction(fn) {
  const id = `action-${++_actionId}`;
  _actionRegistry[id] = fn;
  return id;
}

function _invokeAction(id) {
  const action = _actionRegistry[id];
  if (typeof action === 'function') {
    action();
  }
}

const _state = {
};

const state = new Proxy(_state, {
  set(target, prop, value) {
    target[prop] = value;
    _scheduleRender();
    return true;
  }
});

let _renderPending = false;
function _scheduleRender() {
  if (!_renderPending) {
    _renderPending = true;
    requestAnimationFrame(() => { _renderPending = false; render(); });
  }
}

function render() {
  const app = document.getElementById('app');
  if (!app) return;
  _actionRegistry = Object.create(null);
  _actionId = 0;
  app.innerHTML = renderView();
  _bindEvents();
}

function renderView() {
  return `
        <span class="aura-text">Hello, Aura!</span>
`;
}

const _icons = {'arrow.up':'⬆️','arrow.up.circle.fill':'⬆️','trash':'🗑','trash.fill':'🗑','plus':'+','plus.circle':'+','minus':'−','star':'⭐','star.fill':'⭐','heart':'❤️','heart.fill':'❤️','checkmark':'✅','checkmark.circle':'✅','xmark':'❌','magnifyingglass':'🔍','gear':'⚙️','person':'👤','house':'🏠','bell':'🔔','camera':'📷','photo':'🖼️','sun.max':'☀️','cloud':'☁️','cloud.rain':'🌧️','cloud.snow':'🌨️','drop':'💧','wind':'💨','lock.circle':'🔒','lock':'🔒','phone':'📞','video':'📹','mic':'🎤','cart':'🛒','inbox':'📥','square.and.pencil':'✏️','bubble.left.and.bubble.right':'💬',};
function _icon(n) { return _icons[n] || n; }

function _bindEvents() {
  document.querySelectorAll('[data-action-id]').forEach(el => {
    const id = el.dataset.actionId;
    el.onclick = event => {
      event.preventDefault();
      _invokeAction(id);
    };
  });
  // Bind input elements to state
  document.querySelectorAll('[data-bind]').forEach(el => {
    const key = el.dataset.bind;
    if (el.type === 'checkbox') {
      el.checked = !!state[key];
      el.onchange = () => { state[key] = el.checked; };
    } else {
      el.value = state[key] || '';
      el.oninput = () => { state[key] = el.value; };
    }
  });
}

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', render);
