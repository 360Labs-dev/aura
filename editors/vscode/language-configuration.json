{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(app|screen|model|component|view|action|fn|on|style|theme|if|else|each|when|is|column|row|stack|grid|scroll|wrap)\\b",
    "decreaseIndentPattern": "^\\s*(\\}|\\]|\\))"
  },
  "folding": {
    "offSide": true
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
